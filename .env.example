# MemeCopy Lab — example environment.
# Copy to .env and fill in. NEVER commit .env. All keys are OPTIONAL:
# if a key is missing, the corresponding adapter is DISABLED, not crashed.

# Solana RPC / WebSocket (read-only usage only)
SOLANA_RPC_URL=
SOLANA_WS_URL=

# Optional enrichment adapters
HELIUS_API_KEY=
BIRDEYE_API_KEY=

# Paper trading config (no real money — ever)
PAPER_INITIAL_BALANCE=1000
MAX_POSITION_PCT=0.15
MAX_OPEN_POSITIONS=3
COPY_LATENCY_SECONDS=30

# There is NO live-trading key here by design. See docs/live-trading-ban.md.
